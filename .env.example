# ── CareSwarm configuration ──────────────────────────────────
# Where GGUF models + QVAC cache live (gitignored; needs ~7GB free).
# Point these at an external drive if your main disk is tight.
QVAC_MODELS_DIR=./models
QVAC_CACHE_DIR=./.qvac-cache

# Service ports
ORCHESTRATOR_PORT=4000
AGENTS_PORT=3001
PROVIDER_PORT=3002

# Service URLs (cross-process)
ORCHESTRATOR_URL=http://localhost:4000
AGENTS_URL=http://localhost:3001
PROVIDER_URL=http://localhost:3002

# Per-process RAM budget for QVAC models (GB). 8GB machine defaults:
# orchestrator 1.8 / agents 4.0 / provider 3.6 — set per process in demo.sh
QVAC_RAM_BUDGET_GB=4.0

# ── Optional: settle session balances on Plasma testnet (Tether L1) ──
# Fully optional — the demo runs 100% offline without it. Disclosed in APIS.json.
PLASMA_MODE=off
PLASMA_RPC_URL=https://testnet-rpc.plasma.to
PLASMA_CHAIN_ID=9746
PLASMA_PRIVATE_KEY=
